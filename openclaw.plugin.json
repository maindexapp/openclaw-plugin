{
  "id": "maindex",
  "name": "Maindex",
  "version": "1.0.0",
  "description": "Persistent relational memory for AI agents. A structured knowledge graph with multi-tier search, typed associations, collections, and full revision history — connected via MCP with OAuth.",
  "kind": "tooling",
  "skills": ["skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "https://maindex.io/mcp",
        "description": "Maindex MCP server URL"
      },
      "authMode": {
        "type": "string",
        "enum": ["oauth", "apiKey"],
        "default": "oauth",
        "description": "Authentication mode: oauth (browser-based) or apiKey (manual)"
      }
    }
  },
  "homepage": "https://maindex.io",
  "repository": "https://github.com/maindexapp/maindex-openclaw-plugin",
  "license": "MIT"
}
